    "feedback:dev": "ugly-app feedback:dev",
    "feedback:prod": "ugly-app feedback:prod",
    "dev-logs": "ugly-app dev-logs",
    "start": "node dist/server/index.mjs",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "textGen": "ugly-app textGen",
    "imageGen": "ugly-app imageGen",
    "upgrade": "node -e \"const e=require('child_process').execSync,x=require('fs').existsSync,g=require('fs').readdirSync;g('node_modules').filter(f=>f.startsWith('.ugly-app-')).forEach(f=>require('fs').rmSync('node_modules/'+f,{recursive:true,force:true}));e(x('yarn.lock')?'yarn add ugly-app@latest':x('pnpm-lock.yaml')?'pnpm add ugly-app@latest':'npm install ugly-app@latest',{stdio:'inherit'});e('node node_modules/ugly-app/dist/cli/index.js upgrade',{stdio:'inherit'})\"",
    "db:schema-gen": "ugly-app db:schema-gen",
    "db:schema-status": "ugly-app db:schema-status"
  },
